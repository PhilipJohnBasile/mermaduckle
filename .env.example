# Neon Postgres connection string (required)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Ollama LLM endpoint (optional, defaults to http://localhost:11434)
OLLAMA_URL=http://localhost:11434

# Server bind address (optional, defaults to 0.0.0.0)
HOST=0.0.0.0

# Server port (optional, defaults to 3001)
PORT=3001

# Comma-separated list of bootstrap admin emails (optional)
ADMIN_EMAILS=you@example.com
